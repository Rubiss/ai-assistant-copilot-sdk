# Discord Application credentials (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here
DISCORD_APP_ID=your_application_id_here

# Guild (server) ID for development - commands register instantly to this guild
DISCORD_GUILD_ID=your_test_server_id_here

# Optional: comma-separated channel IDs where the bot responds to ALL messages (no @mention needed)
# Right-click a channel in Discord → Copy Channel ID (requires Developer Mode in Discord settings)
# Example: DISCORD_FREE_CHANNELS=123456789012345678,987654321098765432
DISCORD_FREE_CHANNELS=

# Optional: comma-separated Discord user IDs allowed to use the bot.
# If set, all other users are silently ignored (messages) or get an ephemeral error (slash commands).
# Right-click your username in Discord → Copy User ID (requires Developer Mode in Discord settings)
# Example: DISCORD_ALLOWED_USERS=123456789012345678
DISCORD_ALLOWED_USERS=

# Optional: timeout in milliseconds for Copilot agent responses. Default: 600000 (10 minutes).
# Increase if MCP tools or complex agent tasks regularly exceed 10 minutes.
# COPILOT_TIMEOUT_MS=600000

# Optional: MCP server secrets for workspace .vscode/mcp.json ${input:xxx} values.
# Format: MCP_INPUT_<ID_UPPERCASE> where hyphens become underscores.
# Example: MCP_INPUT_GRAFANA_SERVICE_ACCOUNT_TOKEN=your_token_here
# Example: MCP_INPUT_PORTAINER_API_TOKEN=your_token_here
