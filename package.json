{
  "name": "ai-assistant",
  "version": "1.0.14",
  "description": "Personal Discord bot backed by the GitHub Copilot SDK",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rubiss/ai-assistant-copilot-sdk.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ai-assistant": "./dist/src/cli.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "start:bot": "node dist/src/cli.js start-bot",
    "start:worker": "node dist/src/cli.js start-worker",
    "start:all": "node dist/src/cli.js start-all",
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "register": "tsx scripts/register-commands.ts",
    "postinstall": "node dist/scripts/patch-deps.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "undici": "^6.24.0"
  }
}
